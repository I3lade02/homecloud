PICLOUD_NAME=Ondruv PiCloud
PICLOUD_VERSION=0.1.0

POSTGRES_DB=picloud
POSTGRES_USER=picloud
POSTGRES_PASSWORD=picloud-dev-password
DATABASE_URL=postgresql://picloud:picloud-dev-password@postgres:5432/picloud

VALKEY_URL=redis://valkey:6379
STORAGE_PATH=/data

API_HOST=0.0.0.0
API_PORT=4000

API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

COOKIE_SECURE=false
SESSION_TTL_DAYS=30
