PICLOUD_NAME=Ondruv PiCloud
PICLOUD_VERSION=0.5.0

POSTGRES_DB=picloud
POSTGRES_USER=picloud
POSTGRES_PASSWORD=picloud-dev-password
DATABASE_URL=postgresql://picloud:picloud-dev-password@postgres:5432/picloud

VALKEY_URL=redis://valkey:6379
STORAGE_PATH=/data

API_HOST=0.0.0.0
API_PORT=4000

API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

COOKIE_SECURE=false
SESSION_TTL_DAYS=30

# Maximální velikost jednoho souboru: 10 GiB
MAX_UPLOAD_SIZE_BYTES=10737418240

# Velikost jednoho upload chunku: 8 MiB
UPLOAD_CHUNK_SIZE_BYTES=8388608

# Nedokončený upload vyprší za 24 hodin
UPLOAD_SESSION_TTL_HOURS=24
