{
  "name": "picloud",
  "version": "0.4.0",
  "private": "true",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @picloud/web --filter @picloud/api --filter @picloud/worker dev",
    "build": "pnpm --filter @picloud/web build && pnpm --filter @picloud/api build && pnpm --filter @picloud/worker build",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @picloud/database db:generate",
    "db:migrate": "pnpm --filter @picloud/database db:migrate",
    "db:studio": "pnpm --filter @picloud/database db:studio"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  }
}
